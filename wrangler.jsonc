{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "801-visual-website-v5",
  "compatibility_date": "2026-04-16",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
